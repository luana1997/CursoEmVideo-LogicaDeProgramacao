Algoritmo "TESTE VETOR"

Var
   VALORES:VETOR[1..6]DE INTEIRO
   CONTADOR:INTEIRO
Inicio
   PARA CONTADOR <-1 ATE 6 FACA
      ESCREVA("DIGITE O ", CONTADOR, "¤. VALOR ")
      LEIA(VALORES[CONTADOR])
   FIMPARA

   PARA CONTADOR <-1 ATE 6 FACA
   ESCREVA("{",VALORES[CONTADOR], "}")
   FIMPARA
Fimalgoritmo
