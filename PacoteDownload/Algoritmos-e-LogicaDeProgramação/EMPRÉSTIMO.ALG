Algoritmo "EMPRÉSTIMO"

Var
EMPRESTIMO, PARCELAS, JUROS:REAL
Inicio
ESCREVA("QUAL O VALOR DO EMPRÉSTIMO? ")
LEIA(EMPRESTIMO)
ESCREVA("EM QUANTAS PARCELAS? ")
LEIA(PARCELAS)
JUROS<-(EMPRESTIMO*20)/100+EMPRESTIMO
ESCREVAL("O VALOR TOTAL DO EMPRÉSTIMO FOI DE ", JUROS)
ESCREVAL("CADA PARCELA SERÁ NO VALOR DE:",(JUROS/PARCELAS))
Fimalgoritmo