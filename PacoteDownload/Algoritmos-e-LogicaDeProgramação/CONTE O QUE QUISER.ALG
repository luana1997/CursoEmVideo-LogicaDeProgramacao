Algoritmo "CONTE O QUE QUISER"
//

Var
CONTADOR,QUISER,SALTO:INTEIRO
Inicio
CONTADOR<-0
ESCREVA("DIGITE QUALQUER NÚMERO: ")
LEIA(QUISER)
ESCREVA("DIGITE A QUANTIDADE DE SALTO: ")
LEIA(SALTO)
ENQUANTO (CONTADOR<=QUISER)FACA
ESCREVAL(CONTADOR)
CONTADOR<-CONTADOR+SALTO
FIMENQUANTO
ESCREVA(" TERMINEI DE CONTAR")
Fimalgoritmo