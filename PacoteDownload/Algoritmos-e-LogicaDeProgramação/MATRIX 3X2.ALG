Algoritmo "MATRIX 3X2"

Var
   MATRI:VETOR[1..3, 1..2] DE INTEIRO
   LINHA, COLUNA:INTEIRO
Inicio
   PARA LINHA <-1 ATE 3 FACA
      PARA COLUNA<-1 ATE 2 FACA
         ESCREVA("DIGITE O VALOR DA POSIÇĂO [", LINHA, ",", COLUNA, "]: ")
         LEIA(MATRI[LINHA,COLUNA])
      FIMPARA
   FIMPARA

   PARA LINHA <- 1 ATE 3 FACA
      PARA COLUNA <- 1 ATE 2 FACA
         ESCREVA(MATRI[LINHA,COLUNA])
      FIMPARA
      ESCREVAL()
   FIMPARA
Fimalgoritmo