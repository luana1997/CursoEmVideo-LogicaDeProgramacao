Algoritmo "FIBONACCI PARÂMETRO"
Var
   CONTADOR, N1, N2, N3:INTEIRO
PROCEDIMENTO PROXIMOFIBONACCI(VAR A,B:INTEIRO)
VAR C: INTEIRO
Inicio
      C := A+B
      ESCREVA(C)
      A := B
      B := C
FIMPROCEDIMENTO
INICIO
   N1<-0
   ESCREVA(N1)
   N2<-1
   ESCREVA(N2)
   PARA CONTADOR:=3 ATE 10 FACA
      PROXIMOFIBONACCI(N1,N2)
   FIMPARA
Fimalgoritmo
