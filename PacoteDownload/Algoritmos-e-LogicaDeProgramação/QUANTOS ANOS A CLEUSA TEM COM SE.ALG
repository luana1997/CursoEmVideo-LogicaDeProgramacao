Algoritmo "QUANTOS ANOS A CLEUSA TEM COM SE"

Var
   ANODENASC, ANOATUAL, IDADE:INTEIRO
Inicio
   ESCREVA("DIGITE O ANO DE NASCIMENTO DA CLEUSA: " )
   LEIA(ANODENASC)
   ESCREVA("DIGITE O ANO EM QUE ESTAMOS: " )
   LEIA(ANOATUAL)
   IDADE<-(ANOATUAL-ANODENASC)
   ESCREVAL("A CLEUSA ESTÁ FAZENDO",(IDADE), " ANOS")
   SE (IDADE>=21) ENTAO
      ESCREVAL("E JÁ ATINGIU A MAIOR IDADE ")
   SENAO
      ESCREVAL("E AINDA NĂO ATINGIU A MAIOR IDADE ")
   FIMSE
Fimalgoritmo
