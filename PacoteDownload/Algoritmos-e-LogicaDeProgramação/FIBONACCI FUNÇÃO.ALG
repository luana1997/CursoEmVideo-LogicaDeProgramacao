Algoritmo "FIBONACCI FUNÇĂO"
Var
   CONTADOR, N1, N2, N3:INTEIRO
FUNCAO PROXIMOFIBONACCI(VAR A,B:INTEIRO):INTEIRO
VAR C: INTEIRO
Inicio
     C <- A+B
     A <- B
     B <- C
     RETORNE C
FIMFUNCAO
INICIO
   N1<-0
   ESCREVAL(N1)
   N2<-1
   ESCREVAL(N2)
   PARA CONTADOR:=3 ATE 5 FACA
      N3 <- PROXIMOFIBONACCI(N1,N2)
      ESCREVAL (N3)
   FIMPARA
Fimalgoritmo
