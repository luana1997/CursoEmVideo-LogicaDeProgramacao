Algoritmo "SOMA FUN«√O"
//
Var
   N1, N2, S:INTEIRO

FUNCAO SOMA(X,Y:INTEIRO):INTEIRO
INICIO
   RETORNE X + Y
FIMFUNCAO

Inicio
   ESCREVA("DIGITE UM N⁄MERO:")
   LEIA(N1)
   ESCREVA("DIGITE UM N⁄MERO:")
   LEIA(N2)
   S <- SOMA(N1, N2)
   ESCREVAL("A SOMA ENTRE ", N1, " E ",  N2, " … IGUAL A:", S)
Fimalgoritmo