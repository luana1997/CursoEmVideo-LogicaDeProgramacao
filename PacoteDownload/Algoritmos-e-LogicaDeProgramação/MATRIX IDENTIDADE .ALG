Algoritmo "MATRIX IDENTIDADE "

Var
   MATRIID: VETOR[1..4, 1..4]DE INTEIRO
   LINHA, COLUNA: INTEIRO
Inicio
   PARA LINHA <- 1 ATE 4 FACA
      PARA COLUNA <- 1 ATE 4 FACA
         SE (LINHA=COLUNA) ENTAO
            MATRIID[LINHA,COLUNA]<- 1
         SENAO
            MATRIID[LINHA,COLUNA]<- 0
         FIMSE
      FIMPARA
   FIMPARA

   PARA LINHA <- 1 ATE 4 FACA
      PARA COLUNA <- 1 ATE 4 FACA
      ESCREVA(MATRIID[LINHA,COLUNA]:3)
      FIMPARA
      ESCREVAL()
   FIMPARA
Fimalgoritmo