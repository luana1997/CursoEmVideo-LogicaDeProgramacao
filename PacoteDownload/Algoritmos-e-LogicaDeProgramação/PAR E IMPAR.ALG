Algoritmo "PAR E IMPAR"

Var
   NUM:INTEIRO
   RESULTADO:CARACTER

FUNCAO PAROUIMPAR(V:INTEIRO):CARACTER
INICIO
   SE(V%2=0)ENTAO
      RETORNE "PAR"
   SENAO
      RETORNE "IMPAR)
   FIMSE
FIMFUNCAO
Inicio
ESCREVA("DIGITE UM N⁄MERO:")
LEIA(NUM)
RESULTADO<- PAROUIMPAR(NUM)
ESCREVAL("O N⁄MERO", NUM, " … UM VALOR:", RESULTADO)

Fimalgoritmo