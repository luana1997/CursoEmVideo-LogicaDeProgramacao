Algoritmo "SOMA PARÂMETROS REFERĘNCIA"

Var
 X, Y:INTEIRO
 PROCEDIMENTO SOMA(VAR A,B: INTEIRO)
Inicio
A<-A+1
B<-B+2
ESCREVAL("O VALOR DE A É:", A)
ESCREVAL("O VALOR DE B É:", B)
ESCREVAL("A SOMA DE A E B É:", A+B)
FIMPROCEDIMENTO
INICIO
X<-4
Y<-8
SOMA(X,Y)
ESCREVAL("O VALOR DE X É:", X)
ESCREVAL("O VALOR DE Y É:", Y)
Fimalgoritmo