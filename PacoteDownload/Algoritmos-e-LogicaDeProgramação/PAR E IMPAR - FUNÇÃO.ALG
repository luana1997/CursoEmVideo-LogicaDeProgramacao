Algoritmo "PAR E IMPAR - FUNÇÃO"

Var
   NUM:INTEIRO
   RESULTADO:CARACTER

FUNCAO PAROUIMPAR(V:INTEIRO):CARACTER
INICIO
   SE(V%2=0)ENTAO
      RETORNE "PAR"
   SENAO
      RETORNE "IMPAR)
   FIMSE
FIMFUNCAO
Inicio
ESCREVA("DIGITE UM NÚMERO:")
LEIA(NUM)
RESULTADO<- PAROUIMPAR(NUM)
ESCREVAL("O NÚMERO", NUM, " É UM VALOR:", RESULTADO)

Fimalgoritmo
