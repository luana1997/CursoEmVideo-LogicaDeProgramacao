Algoritmo "TESTE ESCOPO"

Var
   NUMERO:INTEIRO
PROCEDIMENTO PAROUIMPAR(V:INTEIRO)
INICIO
      ESCREVAL("O VALOR DE V É", V)
      ESCREVAL("O VALOR DE NÚMERO É", NUMERO)
   SE(V%2=0) ENTAO
      ESCREVAL("O NÚMERO", V, " É PAR")
   SENAO
      ESCREVAL("O NÚMERO", V, " É IMPAR")
   FIMSE
FIMPROCEDIMENTO
Inicio
   ESCREVA("DIGITE UM NÚMERO:")
   LEIA(NUMERO)
   PAROUIMPAR(NUMERO)
Fimalgoritmo
