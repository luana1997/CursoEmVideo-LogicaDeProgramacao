Algoritmo "FATORIAL FUNÇĂO"
//
Var
   NUM, F:INTEIRO

FUNÇĂO FATORIAL(VALOR: INTEIRO):INTEIRO
VAR
   CONTADOR, RESULTADO:INTEIRO

INICIO
   RESULTADO<-1
   PARA CONTADOR <-1 ATE VALOR FACA
      RESULTADO <- RESULTADO*CONTADOR
   FIMPARA
   RETORNE RESULTADO
FIMFUNCAO

Inicio
   ESCREVA("DIGITE UM NÚMERO:")
   LEIA(NUM)
   F <- FATORIAL(NUM)
   ESCREVAL("O VALOR DE", NUM, "! É IGUAL A", F)
Fimalgoritmo