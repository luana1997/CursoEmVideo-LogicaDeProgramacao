Algoritmo "CRIANÇA ESPERANÇA"
// 
Var
DOACAO:INTEIRO
VALOR:REAL
Inicio
ESCREVAL("[1] PARA DOAR R$10 ")
ESCREVAL("[2] PARA DOAR R$25 ")
ESCREVAL("[3] PARA DOAR R$50 ")
ESCREVAL("[4] PARA DOAR OUTROS VALORES ")
ESCREVAL("[5] PARA CANCELAR ")
LEIA(DOACAO)
ESCOLHA DOACAO
CASO 1
VALOR<-10
CASO 2
VALOR<-25
CASO 3
VALOR<-50
CASO 4
ESCREVA("DIGITE O VALOR DE DOAÇĂO: ")
LEIA(DOACAO)
VALOR<-DOACAO
CASO 5
VALOR<-0
FIMESCOLHA
ESCREVAL("SUA DOAÇĂO FOI DE:", VALOR)
Fimalgoritmo