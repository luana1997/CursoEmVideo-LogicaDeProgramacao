Algoritmo "CONVERSĂO DOLAR"

Var
   CONTADOR,QUANT:INTEIRO
   REAIS, DOLAR:REAL
Inicio
   CONTADOR <- 1
   ESCREVAL("QUANTAS CONVERSŐES VOCĘ QUER FAZER? ")
   LEIA(QUANT)
   ENQUANTO (CONTADOR<=QUANT) FACA
      ESCREVA("QUAL O VALOR VOCĘ QUER CONVERTER: ")
      LEIA(REAIS)
      DOLAR<-REAIS/2.20
      ESCREVAL("o VALOR CONVERTIDO FOI DE: ", DOLAR:5:2)
      CONTADOR<-CONTADOR+1
   FIMENQUANTO
Fimalgoritmo