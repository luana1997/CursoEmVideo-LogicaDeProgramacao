Algoritmo "VALORES ENTRE 0 E 10 - PARA"

Var
   CONTADOR, NUM, TOTAL_010:INTEIRO
Inicio
   TOTAL_010<-0
   PARA CONTADOR <-1 ATE 6 FACA
      ESCREVAL("DIGITE UM VALOR:")
      LEIA(NUM)
      SE (NUM>=0) E (NUM <=10)ENTAO
         TOTAL_010<-TOTAL_010+1
      FIMSE
   FIMPARA
   ESCREVAL("AO TODO FORAM ", TOTAL_010, " NÖMEROS DIGITADOS ENTRE 0 E 10")
Fimalgoritmo