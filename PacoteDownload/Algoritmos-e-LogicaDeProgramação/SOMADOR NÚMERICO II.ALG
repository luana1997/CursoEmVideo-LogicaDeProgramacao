Algoritmo "SOMADOR N⁄MERICO II"

Var
CONTADOR,N,SOMA,MAIOR,MENOR:INTEIRO
Inicio
CONTADOR<-1
SOMA<-0
ENQUANTO (CONTADOR<=5)FACA
ESCREVA("DIGITE O", CONTADOR,"O.VALOR: ")
LEIA(N)
SE(N>MAIOR)ENTAO
MAIOR<-N
FIMSE
SE(N<MENOR)ENTAO
MENOR<-N
FIMSE
SOMA<-SOMA+CONTADOR
CONTADOR<-CONTADOR+1
FIMENQUANTO
ESCREVAL("A SOMA DE TODOS OS VALORES … DE:", SOMA)
ESCREVAL("O MAIOR N⁄MERO DIGITADO FOI: ", MAIOR)
ESCREVAL("O MENOR N⁄MERO DIGITADO FOI: ", MENOR)
Fimalgoritmo