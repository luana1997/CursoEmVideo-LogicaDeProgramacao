Algoritmo "IMC"

Var
   ALTURA, PESO, IMC:REAL
Inicio
   ESCREVA("DIGITE SUA ALTURA: ")
   LEIA(ALTURA)
   ESCREVA("DIGITE O SEU PESO: ")
   LEIA(PESO)
   IMC<- PESO/(ALTURA^2)
   ESCREVAL("O SEU IMC É DE:", IMC:5:2)
   SE (IMC >= 18.6) E (IMC<25) ENTAO
      ESCREVAL("PARABÉNS! VOCĘ ESTÁ NO PESO IDEAL ")
   SENAO
      ESCREVAL("MELHORE! VOCĘ NĂO ESTÁ NO PESO IDEAL ")
   FIMSE
Fimalgoritmo