Algoritmo "PROCEDIMENTO PAR OU IMPAR"

Var
   NUMERO:INTEIRO
PROCEDIMENTO PAROUIMPAR(V:INTEIRO)
INICIO
   SE(V%2=0) ENTAO
      ESCREVAL(" O NĞMERO", V, " … PAR")
   SENAO
      ESCREVAL(" O NĞMERO", V, " … IMPAR")
   FIMSE
FIMPROCEDIMENTO
Inicio
   ESCREVA("DIGITE UM NĞMERO:")
   LEIA(NUMERO)
   PAROUIMPAR(NUMERO)
Fimalgoritmo